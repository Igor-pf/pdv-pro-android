{
  "manifest_version": 2,
  "name": "GeckoViewBridge",
  "version": "1.0",
  "description": "Bridge for Android-JS communication",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": ["nativeMessaging"]
}
